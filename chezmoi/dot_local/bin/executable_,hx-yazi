#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 2 ]]; then
	echo "Usage: ,hx-yazi <path> <chooser-file>" >&2
	exit 1
fi

target="$1"
chooser_file="$2"

start_dir=""
if [[ -f "$target" ]]; then
	start_dir="$(dirname "$target")"
elif [[ -d "$target" ]]; then
	start_dir="$target"
elif git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
	start_dir="$git_root"
else
	start_dir="$PWD"
fi

if [[ -n "${ZELLIJ:-}" ]]; then
	exec zellij run --floating --close-on-exit --block-until-exit --name yazi --x "7%" --y "7%" --width "86%" --height "86%" --cwd "$start_dir" -- yazi "$start_dir" --chooser-file="$chooser_file"
fi

exec yazi "$start_dir" --chooser-file="$chooser_file"
