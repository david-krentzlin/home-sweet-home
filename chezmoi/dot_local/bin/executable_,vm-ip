#!/usr/bin/env bash
set -euo pipefail

if ! command -v limactl >/dev/null 2>&1; then
	echo "Error: limactl is required but was not found on PATH." >&2
	exit 1
fi

INSTANCE_NAME="dev"

while [[ $# -gt 0 ]]; do
	case "$1" in
	--vm-name)
		INSTANCE_NAME="$2"
		shift 2
		;;
	-h | --help)
		echo "Usage: ,vm-ip [--vm-name NAME]"
		exit 0
		;;
	*)
		echo "Error: unknown argument '$1'." >&2
		exit 1
		;;
	esac
done

VM_IP="$(limactl shell --workdir /home/dev "$INSTANCE_NAME" sh -lc "ip -j -4 addr show dev lima0 | jq -r '.[0].addr_info | map(select(.family == \"inet\")) | .[0].local // empty'")"

if [[ -z "$VM_IP" ]]; then
	echo "Error: no IPv4 address found for interface lima0 on VM '$INSTANCE_NAME'. Ensure vzNAT is enabled and restart the VM." >&2
	exit 1
fi

printf '%s\n' "$VM_IP"
