#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INSTANCE_NAME="dev"
PORT=""

while [[ $# -gt 0 ]]; do
	case "$1" in
	--vm-name)
		INSTANCE_NAME="$2"
		shift 2
		;;
	-h | --help)
		echo "Usage: ,vm-open [PORT] [--vm-name NAME]"
		exit 0
		;;
	*)
		if [[ -n "$PORT" ]]; then
			echo "Error: only one port may be provided." >&2
			exit 1
		fi
		PORT="$1"
		shift
		;;
	esac
done

if [[ -n "$PORT" && ! "$PORT" =~ ^[0-9]+$ ]]; then
	echo "Error: port must be numeric." >&2
	exit 1
fi

VM_IP="$($SCRIPT_DIR/,vm-ip --vm-name "$INSTANCE_NAME")"
URL="http://$VM_IP"

if [[ -n "$PORT" ]]; then
	URL+=":$PORT"
fi

if command -v open >/dev/null 2>&1; then
	exec open "$URL"
elif command -v xdg-open >/dev/null 2>&1; then
	exec xdg-open "$URL"
else
	echo "Error: neither 'open' nor 'xdg-open' is available on PATH." >&2
	exit 1
fi
