{{- $darwin := eq .chezmoi.os "darwin" -}}
{{- $needsTaskwarrior := false -}}
{{- $manageLimaVMsFromThisHost := false -}}
{{- $hasGui := false -}}
{{- if hasKey . "needs_taskwarrior" }}{{- $needsTaskwarrior = .needs_taskwarrior }}{{- end }}
{{- if hasKey . "manage_lima_vms_from_this_host" }}{{- $manageLimaVMsFromThisHost = .manage_lima_vms_from_this_host }}{{- end }}
{{- if hasKey . "has_gui" }}{{- $hasGui = .has_gui }}{{- end }}

{{- if or .develop (not $manageLimaVMsFromThisHost) }}
.local/bin/,vm-shell
.local/bin/,vm-create
.local/bin/,vm-sync-jfrog
.local/bin/,vm-ip
.local/bin/,vm-open
{{- end }}

{{- if .develop }}
.config/zsh/rc.d/05_homebrew
.config/zsh/rc.d/10_java
{{- end }}

{{- if not $hasGui }}
.config/wezterm
.config/wezterm/**
{{- end }}

{{- if not .develop }}
.ssh/config
.npmrc
.yarnrc
.yarnrc.yml
{{- end }}

{{- if not $darwin }}
.config/zsh/rc.d/05_homebrew
.config/zsh/rc.d/10_java
Library/Application Support/lazygit/config.yml
{{- end }}

{{- if not .needs_opencode }}
.config/opencode
.config/opencode/**
{{- end }}

{{- if not $needsTaskwarrior }}
.taskrc
.taskrc.d
.taskrc.d/**
.local/bin/,task-popup
{{- end }}
