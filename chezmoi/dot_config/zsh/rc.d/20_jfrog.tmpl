if [[ -f "$HOME/.ivy2/.credentials" ]]; then
	export SBT_CREDENTIALS="$HOME/.ivy2/.credentials"
fi

if [[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/coursier/credentials.properties" ]]; then
	export COURSIER_CREDENTIALS="${XDG_CONFIG_HOME:-$HOME/.config}/coursier/credentials.properties"
fi

,jfrog_oidc_status() {
	if [[ -n "${JFROG_OIDC_USER:-}" && -n "${JFROG_OIDC_TOKEN:-}" ]]; then
		echo "JFrog OIDC environment is loaded"
	else
		echo "JFrog OIDC environment is not loaded"
	fi

	if [[ -f "$HOME/.ivy2/.credentials" ]]; then
		echo "sbt credentials file present"
	else
		echo "sbt credentials file missing"
	fi

	if [[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/coursier/credentials.properties" ]]; then
		echo "Coursier credentials file present"
	else
		echo "Coursier credentials file missing"
	fi
}

,jfrog_oidc_env() {
	echo "Exporting jfrog credentials from password manager"
	{{- if .op }}
		export JFROG_OIDC_USER="$(op read "op://{{ .jfrog_secret_path }}/username")"
		export JFROG_OIDC_TOKEN="$(op read "op://{{ .jfrog_secret_path }}/password")"
	{{- else if .gopass }}
		export JFROG_OIDC_USER="$(gopass show -o websites/{{- .jfrog_secret_path }} username)"
		export JFROG_OIDC_TOKEN="$(gopass show -o websites/{{- .jfrog_secret_path -}})"
	{{- else }}
		echo "Could not find your password manager. Neither op nor gopass found."
		return 1
	{{- end }}

	export JFROG_CREDENTIALS=$JFROG_OIDC_USER:$JFROG_OIDC_TOKEN
	echo "Set JFROG_OIDC_USER and JFROG_OIDC_TOKEN"
}

