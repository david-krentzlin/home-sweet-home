// ~/.config/zellij/layouts/dev.kdl

layout {
    pane size=1 borderless=true {
        plugin location="compact-bar"
    }

    pane split_direction="vertical" {
        pane name="hx" command="zsh" size="70%" focus=true {
            args "-lc" "exec hx"
        }
        pane name="shell" size="30%"
    }
}
